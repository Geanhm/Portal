@model Portal.Web.Views.Dashboard.DashboardView

@{
    ViewData["Title"] = "Dashboard de Gestão";
}

<div class="container-fluid">
    <h1 class="mt-4">Dashboard</h1>

    <div class="row mt-4">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Total Invoices</div>
                    <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalInvoices</div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Valor Aprovadas</div>
                    <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.ValorTotalAprovadas.ToString("C")</div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-warning shadow h-100 py-2">
                <div class="card-body">
                    <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Comissões Pendentes</div>
                    <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalComissoesPendentes.ToString("C")</div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-info shadow h-100 py-2">
                <div class="card-body">
                    <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Comissões Pagas</div>
                    <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalComissoesPagas.ToString("C")</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Top 5 Vendedores</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>Nome do Vendedor</th>
                            <th>Total de Comissão</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var vendedor in Model.TopVendedores)
                        {
                            <tr>
                                <td>@vendedor.Nome</td>
                                <td>@vendedor.TotalComissao.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>