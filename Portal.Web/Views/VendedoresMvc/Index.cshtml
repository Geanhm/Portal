@{
    ViewData["Title"] = "Gestão de Vendedores";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-people"></i> Vendedores</h2>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalVendedor" onclick="configurarParaNovo()">
            <i class="bi bi-person-plus"></i> Novo Vendedor
        </button>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Nome</th>
                        <th>CPF</th>
                        <th>E-mail</th>
                        <th>Telefone</th>
                        <th>Comissão (%)</th>
                        <th>Status</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody id="listaVendedores">
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="modalVendedor" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitulo">Dados do Vendedor</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="formVendedor">
                    <input type="hidden" id="vendedorId" />
                    <div class="mb-3">
                        <label class="form-label">Nome Completo</label>
                        <input type="text" id="nomeCompleto" class="form-control" required />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">CPF</label>
                            <input type="text" id="cpf" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Comissão (%)</label>
                            <input type="number" id="percentualComissao" class="form-control" step="0.1" required />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Telefone</label>
                            <input type="text" id="telefone" class="form-control" maxlength="15" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Status</label>
                            <select id="status" class="form-select">
                                <option value="Ativo">Ativo</option>
                                <option value="Inativo">Inativo</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">E-mail</label>
                        <input type="email" id="email" class="form-control" required />
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" onclick="salvarVendedor()">Salvar</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const API_VENDEDOR = '/api/Vendedores';

        async function carregarVendedores() {
            const res = await fetch(API_VENDEDOR);
            const data = await res.json();
            const tbody = document.getElementById('listaVendedores');

            tbody.innerHTML = data.map(v => `
                <tr>
                    <td class="fw-bold">${v.nomeCompleto}</td>
                    <td>${v.cpf}</td>
                    <td>${v.email}</td>
                    <td>${v.telefone || '-'}</td>
                    <td>${v.percentualComissao}%</td>
                    <td>
                        <span class="badge ${v.status === 'Ativo' ? 'bg-success' : 'bg-danger'}">
                            ${v.status || 'Ativo'}
                        </span>
                    </td>
                    <td class="text-center">
                        <button class="btn btn-sm btn-outline-primary" onclick="editarVendedor('${v.id}')"><i class="bi bi-pencil"></i></button>
                        <button class="btn btn-sm btn-outline-danger" onclick="excluirVendedor('${v.id}')"><i class="bi bi-trash"></i></button>
                    </td>
                </tr>
            `).join('');
        }

        async function salvarVendedor() {
            const id = document.getElementById('vendedorId').value;
            const body = {
                nomeCompleto: document.getElementById('nomeCompleto').value,
                cpf: document.getElementById('cpf').value,
                email: document.getElementById('email').value,
                telefone: document.getElementById('telefone').value,
                percentualComissao: parseFloat(document.getElementById('percentualComissao').value),
                status: document.getElementById('status').value
            };

            const method = id ? 'PUT' : 'POST';
            const url = id ? `${API_VENDEDOR}/${id}` : API_VENDEDOR;

            const res = await fetch(url, {
                method: method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            });

            if (res.ok) {
                bootstrap.Modal.getInstance(document.getElementById('modalVendedor')).hide();
                document.getElementById('formVendedor').reset();
                document.getElementById('vendedorId').value = '';
                carregarVendedores();
            } else {
                const errorData = await res.json();
                let msg = "Erro na validação:\n";

                if (errorData.errors) { // Erros do ModelState (DataAnnotations)
                    for (let prop in errorData.errors) {
                        msg += `- ${errorData.errors[prop]}\n`;
                    }
                } else if (errorData.error) { // Erro da sua BusinessException
                    msg = errorData.error;
                } else {
                    msg = "Ocorreu um erro inesperado.";
                }
                alert(msg);
            }
        }

        function configurarParaNovo() {
            document.getElementById('formVendedor').reset();
            document.getElementById('vendedorId').value = '';
            document.getElementById('modalTitulo').innerText = "Novo Vendedor";
        }

        async function editarVendedor(id) {
            const res = await fetch(`${API_VENDEDOR}/${id}`);
            if (res.ok) {
                const v = await res.json();
                document.getElementById('vendedorId').value = v.id;
                document.getElementById('nomeCompleto').value = v.nomeCompleto;
                document.getElementById('cpf').value = v.cpf;
                document.getElementById('email').value = v.email;
                document.getElementById('telefone').value = v.telefone || '';
                document.getElementById('percentualComissao').value = v.percentualComissao;
                document.getElementById('status').value = v.status || 'Ativo';

                document.getElementById('modalTitulo').innerText = "Editar Vendedor";
                new bootstrap.Modal(document.getElementById('modalVendedor')).show();
            }
        }

        async function excluirVendedor(id) {
            if (confirm("Deseja realmente excluir este vendedor?")) {
                const res = await fetch(`${API_VENDEDOR}/${id}`, { method: 'DELETE' });
                if (res.ok) carregarVendedores();
                    else {
                    const errorData = await res.json();
                    let msg = "Erro na validação:\n";

                    if (errorData.errors) { // Erros do ModelState (DataAnnotations)
                        for (let prop in errorData.errors) {
                            msg += `- ${errorData.errors[prop]}\n`;
                        }
                    } else if (errorData.error) { // Erro da sua BusinessException
                        msg = errorData.error;
                    } else {
                        msg = "Ocorreu um erro inesperado.";
                    }
                    alert(msg);
                }
            }
        }

        carregarVendedores();
    </script>
}