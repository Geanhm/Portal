<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Portal Comex - @ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body {
            display: flex;
            min-height: 100vh;
            background-color: #f4f7f6;
        }

        .sidebar {
            width: 250px;
            background: #2c3e50;
            color: white;
            min-height: 100vh;
        }

            .sidebar .nav-link {
                color: #bdc3c7;
                padding: 15px 20px;
                transition: 0.3s;
            }

                .sidebar .nav-link:hover, .sidebar .nav-link.active {
                    background: #34495e;
                    color: white;
                }

        .main-content {
            flex: 1;
            padding: 30px;
        }

        .card-kpi {
            border-radius: 10px;
            border: none;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
    </style>
</head>
<body>
    <div class="sidebar d-flex flex-column">
        <div class="p-4 text-center">
            <h4><i class="bi bi-box-seam me-2"></i>Portal</h4>
            <hr>
        </div>
        <nav class="nav flex-column">
            <a class="nav-link" href="/Dashboard"><i class="bi bi-speedometer2 me-2"></i> Dashboard</a>
            <a class="nav-link" href="/Invoices"><i class="bi bi-file-earmark-text me-2"></i> Invoices</a>
            <a class="nav-link" href="/Vendedores"><i class="bi bi-people me-2"></i> Vendedores</a>
        </nav>
    </div>

    <div class="main-content">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>